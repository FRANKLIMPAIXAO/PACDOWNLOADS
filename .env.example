# Variaveis lidas pelo docker-compose.production.yml na raiz do projeto.
# Copie para `.env` (mesma pasta do docker-compose.production.yml) e preencha.

# Postgres (mesma senha precisa estar em backend/.env tambem!)
POSTGRES_DB=pac_xml
POSTGRES_USER=pac
POSTGRES_PASSWORD=TROCAR_SENHA_FORTE_AQUI_MIN_24_CHARS

# URL pública do backend (vai como build-arg para o Next.js embedar)
PUBLIC_API_URL=https://api.SEUDOMINIO.com.br
