# Copie este arquivo para `config.env` e preencha.
# NÃO comite o config.env — ele tem a senha (já está no .gitignore).

# --- API do PAC (produção) ---
PAC_BASE_URL=https://api.pacgestao.com.br
PAC_EMAIL=operador@pacgestao.com.br
PAC_PASSWORD=troque-aqui

# --- Pasta que o DOMÍNIO monitora ---
# De preferência dentro do OneDrive sincronizado, pra espelhar na máquina do
# Domínio sem clique humano. Aceita barra normal (/) no Windows.
PASTA_BASE=C:/Users/SEU_USUARIO/OneDrive/XML-Dominio

# --- O que sincronizar ---
TIPOS=NFE,CTE

# --- RECORTE (essencial pra não baixar o histórico inteiro) ---
# Mês desejado (AAAA-MM). Deriva a janela (1º ao último dia). Ex.: maio = 2026-05.
COMPETENCIA=2026-05
# (opcional) janela crua, sobrepõe a COMPETENCIA se preenchida:
# DATA_MIN=2026-05-01
# DATA_MAX=2026-05-31

# Modelos da NFe: 55 = Nota Fiscal | 65 = NFC-e (cupom de balcão). Vazio = todos.
# Só filtra NFe — CTe passa direto. Ex.: MODELOS=55 exclui os cupons.
MODELOS=55

# CNPJs (14 díg, separados por vírgula) a IGNORAR — empresas de altíssimo volume
# que você trata à parte. Ex.: EXCLUIR_CNPJS=01060996000193,14832685000147
EXCLUIR_CNPJS=

# Dias que o rescan varre pra trás (manifestação tardia de recebida). 0 desliga.
DIAS_RESCAN=15

# Layout: arvore = <base>/<CNPJ>/<AAAA-MM>/<TIPO>/<chave>.xml | plano = tudo numa pasta
LAYOUT=arvore

INCLUIR_CANCELADAS=true
LIMITE_PAGINA=2000
TIMEOUT=60
