# Copie este arquivo para `config.env` e preencha.
# NÃO comite o config.env — ele tem a senha (já está no .gitignore).

# --- API do PAC (produção) ---
PAC_BASE_URL=https://api.pacgestao.com.br
PAC_EMAIL=operador@pacgestao.com.br
PAC_PASSWORD=troque-aqui

# --- Pasta que o DOMÍNIO monitora ---
# De preferência dentro do OneDrive sincronizado, pra espelhar na máquina do
# Domínio sem clique humano. Aceita barra normal (/) no Windows.
PASTA_BASE=C:/Users/SEU_USUARIO/OneDrive/XML-Dominio

# --- O que sincronizar ---
# Fase 1: NFe + CTe (o Domínio importa esses com certeza).
# Some NFSE depois de confirmar que o seu Domínio aceita o XML do ADN.
TIPOS=NFE,CTE

# Dias que o rescan varre pra trás (pega a RECEBIDA que só virou XML completo
# depois da manifestação — id antigo, XML novo). 0 desliga o rescan.
DIAS_RESCAN=15

# Layout da pasta:
#   arvore = <base>/<CNPJ>/<AAAA-MM>/<TIPO>/<chave>.xml   (organizado, recomendado)
#   plano  = <base>/<CNPJ>_<TIPO>_<chave>.xml             (tudo numa pasta só —
#            use se o Domínio NÃO varrer subpastas da pasta monitorada)
LAYOUT=arvore

# Incluir o XML de notas canceladas (evento de cancelamento)? true | false
INCLUIR_CANCELADAS=true

# Teto de documentos por página da API (e por rescan).
LIMITE_PAGINA=2000

# Timeout HTTP em segundos.
TIMEOUT=60
